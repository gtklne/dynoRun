{
  "name": "dynorun-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "./scripts/dev.sh",
    "dev:no-tunnel": "tsx watch --env-file-if-exists=.env src/index.ts",
    "build": "tsc --outDir dist",
    "start": "node dist/index.js",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "better-auth": "^1.2.7",
    "better-call": "^1.3.5",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.10",
    "pg": "^8.14.1",
    "resend": "^4.5.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
