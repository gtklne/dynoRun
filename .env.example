# Public Cloudflare Turnstile site key (safe to expose client-side).
# For local dev, use Cloudflare's "always passes" test site key:
#   1x00000000000000000000AA
VITE_TURNSTILE_SITE_KEY=

# Prefills the dev-only "Dev sign-in" panel on the login screen (dev builds only,
# stripped from prod). Pair with DEV_LOGIN=true in server/.env. See CLAUDE.md → Dev login.
VITE_DEV_LOGIN_EMAIL=
